# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_KEY_PREFIX=token:

# Postgres
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DATABASE=token_migration
PG_POOL_MAX=5

# Migração (Redis → Postgres)
MIGRATION_BATCH_SIZE=100
MIGRATION_BATCH_DELAY_MS=50
MIGRATION_SCAN_CHUNK_SIZE=100
MIGRATION_MAX_RETRIES=3
MIGRATION_RETRY_DELAY_MS=1000
MIGRATION_DRY_RUN=false
